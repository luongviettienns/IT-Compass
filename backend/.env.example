PORT=5000
DATABASE_URL="mysql://root:password@localhost:3306/it_compass_vi"
FRONTEND_URL="http://localhost:5173"

# Auth
JWT_ACCESS_SECRET="change-me-in-production"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=30
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
AUTH_DEBUG_EXPOSE_TOKENS=true
REFRESH_TOKEN_COOKIE_NAME="it_compass_refresh"
COOKIE_SECURE=false
COOKIE_DOMAIN=

# CORS (comma-separated additional origins)
ALLOWED_ORIGINS=

# Upload
UPLOAD_MAX_FILE_SIZE_MB=5
REQUEST_BODY_LIMIT="1mb"

# Metrics (optional, protects /api/metrics endpoint)
METRICS_TOKEN=

# Redis (optional, used for rate limiting in production)
REDIS_URL=
RATE_LIMIT_USE_REDIS=false
